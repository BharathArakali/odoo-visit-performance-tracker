<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="email_template_missed_visit_summary" model="mail.template">
        <field name="name">Missed Visit Summary</field>

        <field name="model_id" ref="model_visit_plan"/>

        <field name="subject">Missed Visit Alert</field>

        <field name="email_from">${user.email}</field>

        <field name="body_html" type="html">
            <![CDATA[
            <p>Hello,</p>

            <p>A scheduled visit was missed.</p>

            <p>Please check the Visit Plan system.</p>
            ]]>
        </field>

    </record>

</odoo>