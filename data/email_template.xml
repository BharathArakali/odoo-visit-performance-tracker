<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">

        <record id="email_template_missed_visit_summary" model="mail.template">
            <field name="name">Missed Visit Summary</field>
            <field name="model_id" ref="model_visit_plan"/>
            <field name="email_from">{{ user.email or '' }}</field>
            <field name="email_to">manager@yourcompany.com</field>
            <field name="subject">Missed Visit Alert: {{ object.name }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 20px; color: #333;">
    <h2 style="color: #d9534f;">Missed Visit Alert</h2>
    <p>Dear Manager,</p>
    <p>The following visit has been marked as <strong style="color: #d9534f;">Missed</strong>:</p>

    <table style="border-collapse: collapse; width: 100%; margin-top: 10px;">
        <tr style="background-color: #f5f5f5;">
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Visit Reference</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.name"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Salesperson</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.salesman_id.name or 'N/A'"/></td>
        </tr>
        <tr style="background-color: #f5f5f5;">
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Retailer</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.retailer_id.name or 'N/A'"/></td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Visit Date</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.date"/></td>
        </tr>
        <tr style="background-color: #f5f5f5;">
            <td style="padding: 8px; border: 1px solid #ddd;"><strong>Productivity Score</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;"><t t-out="object.productivity_score"/> %</td>
        </tr>
    </table>

    <p style="margin-top: 20px;">Please take necessary action.</p>
    <p>Regards,<br/><strong>Visit Performance Tracker</strong></p>
</div>
            ]]></field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>