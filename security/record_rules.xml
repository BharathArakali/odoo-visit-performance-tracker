<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Salesman can only see his own visits -->
        <record id="rule_visit_plan_salesman" model="ir.rule">
            <field name="name">Visit Plan: Salesman sees own visits</field>
            <field name="model_id" ref="model_visit_plan"/>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="domain_force">[('salesman_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager can see all visits (no domain restriction) -->
        <record id="rule_visit_plan_manager" model="ir.rule">
            <field name="name">Visit Plan: Manager sees all visits</field>
            <field name="model_id" ref="model_visit_plan"/>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>