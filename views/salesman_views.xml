<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Salesman List View -->
        <record id="view_salesman_list" model="ir.ui.view">
            <field name="name">salesman.list</field>
            <field name="model">visit.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="salesman_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Salesman Action -->
        <record id="action_salesman" model="ir.actions.act_window">
            <field name="name">Salesmen</field>
            <field name="res_model">visit.plan</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>