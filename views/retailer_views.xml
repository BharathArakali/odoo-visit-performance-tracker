<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Extend res.partner form to add smart button -->
        <record id="view_res_partner_visit_button" model="ir.ui.view">
            <field name="name">res.partner.visit.button</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                    <button class="oe_stat_button"
                            type="object"
                            name="action_view_retailer_visits"
                            icon="fa-map-marker">
                        <field string="Visits" name="retailer_visit_count" widget="statinfo"/>
                    </button>
                </xpath>
            </field>
        </record>

        <!-- Retailer list view under Masters menu -->
        <record id="view_retailer_list" model="ir.ui.view">
            <field name="name">retailer.list</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="Retailers">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="retailer_visit_count" string="Total Visits"/>
                </list>
            </field>
        </record>

        <!-- Action for Masters > Retailers menu -->
        <record id="action_retailer" model="ir.actions.act_window">
            <field name="name">Retailers</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>