<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Retailer List View -->
        <record id="view_retailer_list" model="ir.ui.view">
            <field name="name">Retailers</field>
            <field name="model">visit.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="retailer_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Retailer Action -->
        <record id="action_retailer" model="ir.actions.act_window">
            <field name="name">Retailers</field>
            <field name="res_model">visit.plan</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>